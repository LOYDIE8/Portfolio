@page "/education"

<PageTitle>Education | Shabs</PageTitle>

<h2 class="neon-text mb-4">Training Ground</h2>

<div class="row">
    <div class="col-md-6">
        <div class="content-card">
            <h4 class="neon-text">Elementary School</h4>
            <p>[Insert Elementary School Name]</p>
            <p style="color: var(--text-muted); font-size: 0.9rem;">Graduated: [Year]</p>
        </div>
    </div>
    <div class="col-md-6">
        <div class="content-card">
            <h4 class="neon-text">Junior High School</h4>
            <p>[Insert JHS Name]</p>
            <p style="color: var(--text-muted); font-size: 0.9rem;">Graduated: [Year]</p>
        </div>
    </div>
    <div class="col-md-6">
        <div class="content-card">
            <h4 class="neon-text">Senior High School</h4>
            <p>[Insert SHS Name]</p>
            <p style="color: var(--text-muted); font-size: 0.9rem;">Graduated: [Year]</p>
        </div>
    </div>
    <div class="col-md-6">
        <div class="content-card">
            <h4 class="neon-text">College</h4>
            <p><strong>Computer Science / IT</strong></p>
            <p style="color: var(--text-muted); font-size: 0.9rem;">
                Current Coursework: Operating Systems (Memory management, demand paging) & Networking 1.
            </p>
        </div>
    </div>
</div>