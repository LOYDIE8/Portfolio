@page "/"

<PageTitle>Me | Shabs</PageTitle>

<div class="container mt-5">
    <div class="row align-items-center">
        <div class="col-md-4 text-center mb-4 mb-md-0">
            <div class="profile-img-container mx-auto">
                <img src="favicon.png" alt="Photo of me">
                <span style="color: var(--text-muted); position: absolute; z-index: -1;">[PHOTO HERE]</span>
            </div>
            <h2 class="neon-text mt-4 mb-1" style="font-weight: 700;">Lloyd Capecenio</h2>
            <p style="color: var(--text-muted); font-size: 1.1rem; letter-spacing: 1px;">"Lloydie"</p>
        </div>

        <div class="col-md-8">
            <div class="content-card text-start w-100">
                
                <div class="mb-4">
                    <h3 class="neon-text" style="border-bottom: 1px solid rgba(0, 243, 255, 0.2); padding-bottom: 8px;">About Me</h3>
                    <p class="mt-3" style="color: var(--text-main); line-height: 1.6;">
                       I’m a second-year BSIT student fueled by curiosity and the desire to understand 
                       how things work. I enjoy exploring new ideas, learning new skills, and growing 
                       through both progress and mistakes—even if procrastination occasionally gets 
                       in the way.
                    </p>
                </div>

                <div class="row mt-4">
                    <div class="col-sm-6 mb-3">
                        <div class="d-flex align-items-center mb-1">
                            <span class="bi bi-geo-alt-fill neon-text me-2"></span>
                            <span style="color: var(--text-muted); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px;">Location</span>
                        </div>
                        <p class="mb-0" style="color: var(--text-main); font-weight: 500;">Bakhawan, daanbantayan</p>
                        <p class="mb-0" style="color: var(--text-muted); font-size: 0.9rem;">Cebu, Phillipines</p>
                    </div>

                    <div class="col-sm-6 mb-3">
                        <div class="d-flex align-items-center mb-1">
                            <span class="bi bi-envelope-fill neon-text me-2"></span>
                            <span style="color: var(--text-muted); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px;">Contact</span>
                        </div>
                        <p class="mb-0" style="color: var(--text-main); font-weight: 500;">capecenio3@gmail.com</p>
                    </div>

                    <div class="col-sm-6 mb-3">
                        <div class="d-flex align-items-center mb-1">
                            <span class="bi bi-code-square neon-text me-2"></span>
                            <span style="color: var(--text-muted); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px;">Skills in Progress </span>
                        </div>
                        <p class="mb-0" style="color: var(--text-main); font-weight: 500;">Java, C, Web Dev (HTML/CSS/JS/Blazor)</p>
                    </div>

                    <div class="col-sm-6 mb-3">
                        <div class="d-flex align-items-center mb-1">
                            <span class="bi bi-controller neon-text me-2"></span>
                            <span style="color: var(--text-muted); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px;">Interests</span>
                        </div>
                        <p class="mb-0" style="color: var(--text-main); font-weight: 500;">MilSim, gaming, discovering new things</p>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>